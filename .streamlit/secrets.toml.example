# -----------------------------------------------------------------------------
# Streamlit secrets template. This .example is SAFE to commit; the real
# secrets.toml is git-ignored. On Streamlit Community Cloud, paste the filled-in
# contents into  Manage app > Settings > Secrets  (never commit them).
#
# With NO [data] block set, the app falls back to the bundled in-repo SAMPLE.
# Logins live in portal/auth.py (USERS) — there is NO [auth] secrets block.
# -----------------------------------------------------------------------------

# --- Private data source: a PRIVATE GitHub repo holding the real data ---------
# 1. Create a private repo (e.g. "dashboard-data") with EXACTLY this layout:
#      accuracy_tables/forecast_forward.xlsx
#      accuracy_tables/Accuracy_Table_6.xlsx
#      calculators/HRC - Copy.csv
# 2. Make a fine-grained Personal Access Token (GitHub > Settings > Developer
#    settings > Fine-grained tokens) scoped to ONLY that repo, with READ-ONLY
#    "Contents" permission. Paste it as github_token below.
# The app downloads these files at runtime via the GitHub Contents API
# (data_loader._fetch_private_data_dir) — nothing private is committed here.
#
# github_token       : READ-ONLY Contents. Used for all data reads.
# github_write_token : OPTIONAL. A separate PAT with Contents READ & WRITE, used
#                      ONLY by the Admin tab to save analyst-call text + upload
#                      PDF/PPT decks (written to analyst_calls/ in the same repo).
#                      Omit it to keep the app read-only (Admin save disabled).
#                      If you'd rather use one token, give github_token write
#                      access and skip github_write_token.
[data]
github_owner       = "your-github-username-or-org"
github_repo        = "dashboard-data"
github_ref         = "main"
github_token       = "github_pat_READONLY_XXXXXXXXXXXX"
github_write_token = "github_pat_READWRITE_XXXXXXXXXXX"

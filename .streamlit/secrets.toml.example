# -----------------------------------------------------------------------------
# Secrets template. This .example file is SAFE to commit; the real secrets.toml
# is git-ignored. Two ways to use it:
#   * Local test:  copy this to .streamlit/secrets.toml and fill in real values.
#   * Streamlit Community Cloud:  paste the filled-in contents into
#     Manage app -> Settings -> Secrets  (never commit them).
# With NO secrets set, the app falls back to the bundled SAMPLE data + demo logins.
# -----------------------------------------------------------------------------

# --- Private data source: a PRIVATE GitHub repo holding the real data ---------
# Layout inside that repo must mirror the sample:
#   accuracy_tables/forecast_forward.xlsx
#   accuracy_tables/Accuracy_Table_6.xlsx
#   accuracy_tables/Accuracy_Table_16.xlsx
#   calculators/HRC - Copy.csv
[data]
github_owner = "mlworkstationbigmint-afk"
github_repo  = "dashboard-data"
github_ref   = "main"
# Fine-grained Personal Access Token with READ-ONLY "Contents" permission,
# scoped to ONLY the dashboard-data repo. GitHub -> Settings -> Developer
# settings -> Fine-grained tokens.
github_token = "github_pat__"

# --- Real login credentials (override the built-in demo users) ----------------
# hash = sha256(password) as hex. Generate one with:
#   python -c "import hashlib; print(hashlib.sha256(b'YourPassword').hexdigest())"
[auth.users.adani]
name = "Adani User"
role = "Adani"
hash = "REPLACE_WITH_SHA256_HEX"

[auth.users.admin]
name = "Administrator"
role = "Admin"
hash = "REPLACE_WITH_SHA256_HEX"

# -----------------------------------------------------------------------------
# HISTORICAL TEMPLATE — NOT USED BY THE APP.
#
# This build reads NO secrets: data ships in-repo (portal/data_loader.py) and
# logins are defined in portal/auth.py (USERS dict). Neither the [data] nor the
# [auth] blocks below are consumed anymore. The file is kept only to document
# the earlier private-data / secrets-auth approach in case it is ever restored.
#
# To re-introduce secrets: copy this to .streamlit/secrets.toml (git-ignored) or
# paste it into Streamlit Cloud > Manage app > Settings > Secrets, AND re-add the
# code that reads it (a data-root resolver in data_loader.py and an
# _active_users() override in auth.py).
# -----------------------------------------------------------------------------

# --- (INACTIVE) Private data source: a PRIVATE GitHub repo holding real data ---
# Layout inside that repo would mirror the in-repo data:
#   accuracy_tables/forecast_forward.xlsx
#   accuracy_tables/Accuracy_Table_6.xlsx
#   calculators/HRC - Copy.csv
[data]
github_owner = "mlworkstationbigmint-afk"
github_repo  = "dashboard-data"
github_ref   = "main"
# Fine-grained PAT, READ-ONLY "Contents", scoped to ONLY that repo.
github_token = "github_pat__"

# --- (INACTIVE) Login overrides. Each user: name, role, and password OR hash ---
# hash = sha256(password) as hex:
#   python -c "import hashlib; print(hashlib.sha256(b'YourPassword').hexdigest())"
[auth.users.adani]
name = "Adani User"
role = "Adani"
hash = "REPLACE_WITH_SHA256_HEX"

[auth.users.admin]
name = "Administrator"
role = "Admin"
hash = "REPLACE_WITH_SHA256_HEX"
